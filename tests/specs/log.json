[
  {
    "name": "/log shows error in private chat",
    "steps": [
      {
        "send": { "text": "/log" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "This command works in group chats only. Add me to a group and make me an admin." } }
        ]
      }
    ]
  },
  {
    "name": "/log in group with no history shows empty state",
    "steps": [
      {
        "send": { "text": "/log", "chatType": "supergroup", "chatId": 10 },
        "expect": [
          { "method": "getChatAdministrators" },
          { "method": "editMessageText" }
        ]
      }
    ]
  },
  {
    "name": "/log shows audit entries after a moderation action",
    "steps": [
      {
        "send": { "text": "/warn spamming", "chatType": "supergroup", "chatId": 10, "userId": 1, "firstName": "Admin", "replyToMessageId": 5, "replyToUserId": 200, "replyToFirstName": "Spammer" },
        "expect": [
          { "method": "getChatAdministrators" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "text": "/log", "chatType": "supergroup", "chatId": 10 },
        "expect": [
          { "method": "getChatAdministrators" },
          { "method": "editMessageText" }
        ]
      }
    ]
  }
]