[
  {
    "name": "/summary shows error in private chat",
    "steps": [
      {
        "send": { "text": "/summary" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "This command works in group chats only. Add me to a group and make me an admin." } }
        ]
      }
    ]
  },
  {
    "name": "/summary in group with no activity shows empty state",
    "steps": [
      {
        "send": { "text": "/summary", "chatType": "supergroup", "chatId": 10 },
        "expect": [
          { "method": "getChatAdministrators" },
          { "method": "sendMessage", "payload": { "text": "No moderation activity yet. Activity will show here once the bot starts moderating." } }
        ]
      }
    ]
  },
  {
    "name": "/summary in group with activity shows report",
    "steps": [
      {
        "send": { "text": "/warn spamming", "chatType": "supergroup", "chatId": 10, "userId": 1, "firstName": "Admin", "replyToMessageId": 5, "replyToUserId": 200, "replyToFirstName": "Spammer" },
        "expect": [
          { "method": "getChatAdministrators" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "text": "/summary", "chatType": "supergroup", "chatId": 10 },
        "expect": [
          { "method": "getChatAdministrators" },
          { "method": "sendMessage" }
        ]
      }
    ]
  }
]