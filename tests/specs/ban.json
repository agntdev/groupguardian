[
  {
    "name": "/ban shows error in private chat",
    "steps": [
      {
        "send": { "text": "/ban" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "This command works in group chats only. Add me to a group and make me an admin." } }
        ]
      }
    ]
  },
  {
    "name": "/ban without reply shows usage",
    "steps": [
      {
        "send": { "text": "/ban", "chatType": "supergroup", "chatId": 10 },
        "expect": [
          { "method": "getChatAdministrators" },
          { "method": "sendMessage", "payload": { "text": "Reply to a user's message with /ban <reason> to ban them." } }
        ]
      }
    ]
  },
  {
    "name": "/ban with reply bans the user",
    "steps": [
      {
        "send": { "text": "/ban spammer", "chatType": "supergroup", "chatId": 10, "userId": 1, "firstName": "Admin", "replyToMessageId": 5, "replyToUserId": 200, "replyToFirstName": "BadUser" },
        "expect": [
          { "method": "getChatAdministrators" },
          { "method": "banChatMember" },
          { "method": "sendMessage", "payload": { "text": "🚫 BadUser was banned by Admin.\nReason: spammer" } }
        ]
      }
    ]
  }
]
